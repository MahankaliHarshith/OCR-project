# ─── Sentry Error Tracking (optional) ─────────────────────────────────────
# Get a free DSN at https://sentry.io — catches unhandled exceptions in prod.
# Zero overhead when not set.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENVIRONMENT=production
# SENTRY_TRACES_SAMPLE_RATE=0.2

# ─── Azure Document Intelligence (Cloud OCR) ─────────────────────────────
# Get these from Azure Portal → your Document Intelligence resource → Keys and Endpoint
# Free tier: 500 pages/month at no cost
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://your-resource-name.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=your-api-key-here

# ─── OCR Engine Mode ──────────────────────────────────────────────────────
# "auto"  → Local-first, Azure only when needed (RECOMMENDED — most cost-efficient)
# "azure" → Azure only (fails if Azure unavailable)
# "local" → EasyOCR only (original behavior, no cloud)
OCR_ENGINE_MODE=auto

# ─── Azure Model Strategy (controls cost per scan) ───────────────────────
# "read-only"         → prebuilt-read ONLY ($0.0015/page) — RECOMMENDED for handwritten
# "receipt-only"      → prebuilt-receipt ONLY ($0.01/page) — better for printed receipts
# "receipt-then-read" → Try receipt, fall back to read (WARNING: burns 2 pages!)
AZURE_MODEL_STRATEGY=read-only

# ─── Azure Cost Control ──────────────────────────────────────────────────
# Daily page limit (resets at midnight)
AZURE_DAILY_PAGE_LIMIT=50
# Monthly page limit (set ≤ 500 to stay within free tier)
AZURE_MONTHLY_PAGE_LIMIT=500

# ─── Smart Local-First Routing ───────────────────────────────────────────
# If local OCR confidence >= this AND detections >= min count, skip Azure entirely.
# Lower = saves more Azure pages; Higher = sends more to Azure for accuracy.
LOCAL_CONFIDENCE_SKIP_THRESHOLD=0.72
LOCAL_MIN_DETECTIONS_SKIP=4

# ─── Image Quality Gate (rejects bad images before Azure) ─────────────────
# Saves Azure pages by not sending blurry/dark images to the cloud.
IMAGE_QUALITY_GATE_ENABLED=true
IMAGE_QUALITY_MIN_SHARPNESS=30.0
IMAGE_QUALITY_MIN_BRIGHTNESS=40

# ─── Image Cache (prevents duplicate Azure charges) ──────────────────────
# Same image re-scanned within TTL = free (uses cached result)
IMAGE_CACHE_MAX_SIZE=200
IMAGE_CACHE_TTL=86400

# ─── Production Security ─────────────────────────────────────────────────
# REQUIRED in production — protects DELETE/reset endpoints
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=

# API docs (Swagger UI) — disable in production to hide internal API schema
API_DOCS_ENABLED=false

# Rate limiting (requests per minute per client IP)
RATE_LIMIT_RPM=60
RATE_LIMIT_SCAN_RPM=20

# Trusted reverse proxy IPs (comma-separated) — only these can set X-Forwarded-For
# Default: 127.0.0.1,::1,172.17.0.1 (localhost + Docker gateway)
TRUSTED_PROXIES=

# ─── Server ──────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
LOG_LEVEL=INFO

# CORS origins (comma-separated). Leave empty for localhost defaults.
CORS_ORIGINS=

# ─── Monitoring ──────────────────────────────────────────────────────────
OTEL_TRACING_ENABLED=false
GRAFANA_PASSWORD=
