# ─────────────────────────────────────────────────────────────────────────────
# Handwritten Receipt Scanner — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
#
# All variables have sensible defaults — the app runs out-of-the-box with
# local EasyOCR + SQLite. Only set Azure keys if you want hybrid OCR.
# ─────────────────────────────────────────────────────────────────────────────


# ── API Server ────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false

# Show /docs and /redoc Swagger UI (disable in production)
API_DOCS_ENABLED=false

# CORS: comma-separated origins (default: localhost:8000, 127.0.0.1:8000, localhost:3000)
# CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Rate limiting (requests per minute per client IP)
RATE_LIMIT_RPM=60
RATE_LIMIT_SCAN_RPM=20

# API key for destructive endpoints (DELETE, reset, clear).
# If not set, a random key is auto-generated and logged on startup.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
API_SECRET_KEY=

# Trusted reverse proxy IPs (comma-separated) for X-Forwarded-For
# Default: 127.0.0.1,::1,172.17.0.1 (localhost + Docker gateway)
# TRUSTED_PROXIES=127.0.0.1,10.0.0.0/8


# ── Database ──────────────────────────────────────────────────────────────────
# "sqlite" (default, zero-config) or "postgresql" (requires psycopg2-binary)
DB_BACKEND=sqlite
DB_BACKUP_KEEP_DAYS=7

# PostgreSQL (only when DB_BACKEND=postgresql)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=receipt_scanner
POSTGRES_USER=receipt_app
POSTGRES_PASSWORD=
POSTGRES_MIN_CONN=2
POSTGRES_MAX_CONN=10


# ── OCR Engine ────────────────────────────────────────────────────────────────
# "auto"  → Local-first, Azure only when needed (RECOMMENDED — most cost-efficient)
# "azure" → Azure only (fails if credentials missing)
# "local" → EasyOCR only (no cloud dependency)
OCR_ENGINE_MODE=auto


# ── Azure Document Intelligence (Hybrid OCR) ─────────────────────────────────
# Get these from Azure Portal → Document Intelligence resource → Keys and Endpoint
# Free tier: 500 pages/month at no cost.
# Leave blank to use local EasyOCR only (fully offline).
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=
AZURE_DOCUMENT_INTELLIGENCE_KEY=

# Model strategy:
#   "receipt-only"      → prebuilt-receipt ($0.01/page) — BEST for receipts (DEFAULT)
#   "read-only"         → prebuilt-read ($0.0015/page) — cheapest, raw text only
#   "receipt-then-read" → try receipt, fallback to read (WARNING: may use 2 pages!)
AZURE_MODEL_STRATEGY=receipt-only


# ── Azure Cost Control ───────────────────────────────────────────────────────
# Daily and monthly hard caps (Azure free tier = 500 pages/month)
AZURE_DAILY_PAGE_LIMIT=50
AZURE_MONTHLY_PAGE_LIMIT=500

# Smart routing: skip Azure if local OCR is confident enough
LOCAL_CONFIDENCE_SKIP_THRESHOLD=0.85
LOCAL_MIN_DETECTIONS_SKIP=4
LOCAL_CATALOG_MATCH_SKIP_THRESHOLD=0.3


# ── Image Quality Gate ────────────────────────────────────────────────────────
# Skip Azure for blurry/dark images (saves pages)
IMAGE_QUALITY_GATE_ENABLED=true
IMAGE_QUALITY_MIN_SHARPNESS=30.0
IMAGE_QUALITY_MIN_BRIGHTNESS=40


# ── Image Cache ───────────────────────────────────────────────────────────────
# Prevents paying twice for the same image (LRU cache with TTL)
IMAGE_CACHE_MAX_SIZE=200
IMAGE_CACHE_TTL=86400


# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Structured JSON logging (for Loki / ELK ingestion)
JSON_LOGGING_ENABLED=true
JSON_LOGGING_STDOUT=false


# ── OpenTelemetry Distributed Tracing ─────────────────────────────────────────
OTEL_TRACING_ENABLED=false
OTEL_EXPORTER_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=receipt-scanner
ENVIRONMENT=development


# ── Sentry Error Tracking (optional) ─────────────────────────────────────────
# Get a free DSN at https://sentry.io — catches unhandled exceptions in prod.
# Zero overhead when not set.
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.2
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_SEND_PII=false


# ── Grafana (docker-compose only) ────────────────────────────────────────────
GRAFANA_PASSWORD=


# ── ngrok (for scripts/start_public.py) ──────────────────────────────────────
# NGROK_AUTH_TOKEN=your-ngrok-token-here
