# ─── Python ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl

# ─── Virtual Environment ────────────────────────────────
.venv/
venv/
ENV/

# ─── IDE / Editor ───────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ─── Environment Variables ──────────────────────────────
.env

# ─── Database ───────────────────────────────────────────
*.db
*.db-wal
*.db-shm
backups/*

# ─── Runtime Directories ────────────────────────────────
uploads/*
exports/*
logs/*
models/*
data/*

# ─── Preserve Directory Structure ───────────────────────
!uploads/.gitkeep
!exports/.gitkeep
!logs/.gitkeep
!models/.gitkeep
!data/.gitkeep
!backups/.gitkeep

# ─── Test / CI Artifacts ────────────────────────────────
.pytest_cache/
htmlcov/
.coverage
*.cover

# ─── OS Files ───────────────────────────────────────────
Thumbs.db
.DS_Store
Desktop.ini
